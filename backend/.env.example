# 服务器配置
PORT=3001
NODE_ENV=development

# JWT配置
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d
JWT_EXPIRES_IN_REMEMBER=30d

# MySQL数据库配置（必填：DB_USER、DB_PASSWORD；代码中无默认值）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=yu_ni_xiang_ban

# 跨域配置
ALLOWED_ORIGINS=http://localhost:3000

# 登录限制配置
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# Coze API配置
COZE_API_URL=your-coze-api-url-here
COZE_API_TOKEN=your-coze-api-token-here
